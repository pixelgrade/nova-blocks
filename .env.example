# Copy any needed values to `.env.local`.
# Keep the real `.env.local` file private and out of git.

# Optional bootstrap config for `bin/bootstrap-private`.
# You can also set the private repo once with:
# git config --local novablocks.privateRepo git@github.com:<you>/nova-blocks-private.git

# PRIVATE_REPO_URL=git@github.com:<you>/nova-blocks-private.git
# PRIVATE_SOURCE_DIR=/absolute/path/to/an-existing/private-checkout
# PRIVATE_SYNC_MODE=copy
